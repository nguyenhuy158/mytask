# --- Local dev (docker-compose.yml) ---
API_PORT=8000
FRONTEND_PORT=5173

# --- Production (docker-compose.prod.yml) ---
# oauth2-proxy gates the entire site via Google OAuth.
# Generate cookie secret: openssl rand -base64 32
OAUTH2_PROXY_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
# Restrict logins: "yourcompany.com" or comma list. "*" = any Google account.
OAUTH2_PROXY_EMAIL_DOMAINS=yourcompany.com
OAUTH2_PROXY_REDIRECT_URL=https://task.example.com/oauth2/callback
OAUTH2_PROXY_COOKIE_DOMAINS=task.example.com
OAUTH2_PROXY_WHITELIST_DOMAINS=task.example.com
